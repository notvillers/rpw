#!/bin/bash
set -u
set -o pipefail

# Default variables
length=32
repeat_count=1
use_symbols=0
lower_only=0
challenge_mode=0
numbers_only=0
must_have_number=0
must_have_char=0
must_have_symbol=0
min_length=0
out_path=""
# Output/clipboard options
format="plain"   # plain|json|csv
clipboard=0      # 1 to copy last password to clipboard (pbcopy/xclip/xsel)

# YubiKey challenge-response charset
challenge_charset="abcdef0123456789"

# POSIX-safe symbol set
symbol_charset='-!@#$%^&*()_+=[]{}|;:,.<>?/~'

print_help() {
  cat <<EOF
Usage: $(basename "$0") [options]

R(andom)P(ass)W(ord) generates a random string.

Options:
  -l <length>       Set password length (default: $length)
  -r <count>        Number of generated password(s)
  -s                Include symbols
  -c                Challenge-response charset (for YubiKey)
  -L                Use lowercase alphanumeric only
  -n                Numbers only
  -N                Must contain a digit
  -A                Must contain an alphabetic character
  -S                Must contain a symbol
  -o <file>         Append output(s) to file
  -f <format>       Output format: plain (default), json, csv
  --format=<fmt>    Same as -f (accepts --format=json)
  --clipboard       Copy last generated password to clipboard (pbcopy/xclip/xsel) if available
  -h, --help        Show help
  --easy            Easy password
  --medium          Medium password
  --hard            Hard password
  --yubi-challenge  Yubikey challenge-response
EOF
}

set_easy() {
  length=8
  lower_only=1
}

set_medium() {
  length=16
  must_have_number=1
  must_have_char=1
}

set_hard() {
  length=32
  use_symbols=1
  must_have_number=1
  must_have_char=1
  must_have_symbol=1
}

set_yubi_challenge() {
  lower_only=1
  length=40
  challenge_mode=1
}

args=()
for arg in "$@"; do
  case "$arg" in
    --help) print_help; exit 0 ;;
    --easy) set_easy ;;
    --medium) set_medium ;;
    --hard) set_hard ;;
    --yubi-challenge) set_yubi_challenge ;;
    --clipboard) clipboard=1 ;;
    --format=*) format="${arg#*=}" ;;
    *) args+=("$arg") ;;
  esac
done
set -- "${args[@]:-}"

while getopts ":l:r:sncLNASo:hf:b" opt; do
  case "$opt" in
    l) length="$OPTARG" ;;
    r) repeat_count="$OPTARG" ;;
    s) use_symbols=1 ;;
    n) numbers_only=1 ;;
    c) challenge_mode=1 ;;
    L) lower_only=1 ;;
    N) must_have_number=1 ;;
    A) must_have_char=1 ;;
    S) must_have_symbol=1 ;;
    o) out_path="$OPTARG" ;;
    f) format="$OPTARG" ;;
    b) clipboard=1 ;;
    h) print_help; exit 0 ;;
    \?) printf "Invalid option: -%s\n" "$OPTARG"; exit 1 ;;
  esac
done

# Minimum length enforcement
[ "$must_have_number" -eq 1 ] && ((min_length++))
[ "$must_have_char" -eq 1 ] && ((min_length++))
[ "$must_have_symbol" -eq 1 ] && ((min_length++))

if ! [[ "$length" =~ ^[0-9]+$ ]] || [ "$length" -lt "$min_length" ]; then
  printf "Error: invalid length\n" >&2
  exit 1
fi

if ! [[ "$repeat_count" =~ ^[0-9]+$ ]] || [ "$repeat_count" -lt 1 ]; then
  printf "Error: invalid repeat count\n" >&2
  exit 1
fi

if [[ "$numbers_only" -eq 1 && ( "$use_symbols" -eq 1 || "$challenge_mode" -eq 1 || "$min_length" -gt 0 ) ]]; then
  printf "Error: -n cannot be combined with other constraints\n" >&2
  exit 1
fi

if [[ "$challenge_mode" -eq 1 && ( "$use_symbols" -eq 1 || "$numbers_only" -eq 1 || "$min_length" -gt 0 ) ]]; then
  printf "Error: -c cannot be combined with other constraints\n" >&2
  exit 1
fi

# Charset selection
if [ "$challenge_mode" -eq 1 ]; then
  charset="$challenge_charset"

elif [ "$numbers_only" -eq 1 ]; then
  charset='[:digit:]'
else
  if [ "$lower_only" -eq 1 ]; then
    charset='[:lower:][:digit:]'
  else
    charset='[:alnum:]'
  fi
  if [ "$use_symbols" -eq 1 ] || [ "$must_have_symbol" -eq 1 ]; then
    charset="${charset}[:punct:]"
  fi
fi

# Generator (length-safe)
generate_pw() {
  local pw
  pw=$(LC_ALL=C tr -dc "$charset" < /dev/urandom | head -c "$length")
  [ "${#pw}" -eq "$length" ] || return 1
  printf '%s' "$pw"
}

# Escape a string for JSON (minimal: backslash, double-quote, CR, LF)
json_escape() {
  # awk is used to avoid external dependencies; ensures common escapes
  printf '%s' "$1" | awk 'BEGIN{ORS=""} { gsub(/\\\\/,"\\\\\\\\"); gsub(/\"/,"\\\""); gsub(/\r/,"\\r"); gsub(/\n/,"\\n"); print $0 }'
}

copy_to_clipboard() {
  local data="$1"
  if command -v pbcopy >/dev/null 2>&1; then
    printf '%s' "$data" | pbcopy
    return 0
  elif command -v xclip >/dev/null 2>&1; then
    printf '%s' "$data" | xclip -selection clipboard
    return 0
  elif command -v xsel >/dev/null 2>&1; then
    printf '%s' "$data" | xsel --clipboard --input
    return 0
  fi
  return 1
}

results=()
for ((i=0; i<repeat_count; i++)); do
  while :; do
    password=""
    if ! password="$(generate_pw)"; then
      continue
    fi

    ok=1
    [ "$must_have_number" -eq 1 ] && ! [[ "$password" =~ [0-9] ]] && ok=0
    [ "$must_have_char" -eq 1 ] && ! [[ "$password" =~ [A-Za-z] ]] && ok=0
    [ "$must_have_symbol" -eq 1 ] && ! [[ "$password" =~ [^A-Za-z0-9] ]] && ok=0

    [ "$ok" -eq 1 ] && break
  done

  results+=("$password")
done

# Output formatting
case "$format" in
  plain)
    if [ -n "$out_path" ]; then
      for p in "${results[@]}"; do printf '%s\n' "$p" >> "$out_path"; done
    else
      for p in "${results[@]}"; do printf '%s\n' "$p"; done
    fi
    ;;
  csv)
    # simple CSV: one password per line
    if [ -n "$out_path" ]; then
      for p in "${results[@]}"; do printf '%s\n' "$p" >> "$out_path"; done
    else
      for p in "${results[@]}"; do printf '%s\n' "$p"; done
    fi
    ;;
  json)
    if [ "${#results[@]}" -eq 1 ]; then
      esc=$(json_escape "${results[0]}")
      if [ -n "$out_path" ]; then
        printf '{"password":"%s"}\n' "$esc" >> "$out_path"
      else
        printf '{"password":"%s"}\n' "$esc"
      fi
    else
      if [ -n "$out_path" ]; then
        printf '[' >> "$out_path"
        first=1
        for p in "${results[@]}"; do
          esc=$(json_escape "$p")
          if [ "${first}" -eq 1 ]; then
            printf '"%s"' "$esc" >> "$out_path"
            first=0
          else
            printf ',"%s"' "$esc" >> "$out_path"
          fi
        done
        printf ']\n' >> "$out_path"
      else
        printf '['
        first=1
        for p in "${results[@]}"; do
          esc=$(json_escape "$p")
          if [ "${first}" -eq 1 ]; then
            printf '"%s"' "$esc"
            first=0
          else
            printf ',"%s"' "$esc"
          fi
        done
        printf ']\n'
      fi
    fi
    ;;
  *) printf 'Error: unknown format: %s\n' "$format" >&2; exit 1 ;;
esac

# Clipboard: copy last password if requested; do not fail if no clipboard tool
if [ "$clipboard" -eq 1 ] && [ "${#results[@]}" -gt 0 ]; then
  last_index=$(( ${#results[@]} - 1 ))
  last="${results[$last_index]}"
  copy_to_clipboard "$last" >/dev/null 2>&1 || true
fi
